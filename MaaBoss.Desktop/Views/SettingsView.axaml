<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MaaBoss.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MaaBoss.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Spacing="16">
      <TextBlock Text="设置" FontSize="24" FontWeight="Bold"/>

      <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="控制器" FontSize="18" FontWeight="SemiBold"/>
          <StackPanel Spacing="8">
            <TextBlock Text="Win32 控制器预设" Opacity="0.7"/>
            <ComboBox ItemsSource="{Binding ControllerPresets}"
                      SelectedItem="{Binding SelectedControllerPreset}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="修改后需重新连接生效" FontSize="12" Opacity="0.5"/>
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="窗口名称" Opacity="0.7"/>
            <TextBox Text="{Binding Win32WindowName}" Watermark="BOSS直聘"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="业务参数" FontSize="18" FontWeight="SemiBold"/>
          <StackPanel Spacing="8">
            <TextBlock Text="识别速率限制 (ms)" Opacity="0.7"/>
            <NumericUpDown Value="{Binding RateLimitMs}" Minimum="100" Maximum="10000" Increment="100"/>
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="默认超时 (ms)" Opacity="0.7"/>
            <NumericUpDown Value="{Binding TimeoutMs}" Minimum="1000" Maximum="120000" Increment="1000"/>
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="每日沟通上限" Opacity="0.7"/>
            <NumericUpDown Value="{Binding DailyGreetLimit}" Minimum="1" Maximum="1000" Increment="10"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="调试" FontSize="18" FontWeight="SemiBold"/>
          <CheckBox Content="保存识别标注图" IsChecked="{Binding SaveDebugDraw}"/>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="MCP Server" FontSize="18" FontWeight="SemiBold"/>
          <StackPanel Spacing="8">
            <TextBlock Text="服务地址" Opacity="0.7"/>
            <TextBox Text="{Binding McpServerUrl}" Watermark="http://localhost:5000"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Content="恢复默认" Command="{Binding ResetDefaultsCommand}"/>
        <Button Content="保存" Command="{Binding SaveSettingsCommand}"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
