{
    "EnterChatList": {
        "recognition": "TemplateMatch",
        "template": "chat/tab_message.png",
        "action": "Click",
        "next": ["FindUnread"]
    },
    "FindUnread": {
        "recognition": "OCR",
        "expected": ["{{contact_name}}"],
        "action": "Click",
        "next": ["InputMessage"]
    },
    "InputMessage": {
        "recognition": "TemplateMatch",
        "template": "chat/input_box.png",
        "action": "Click",
        "next": ["TypeMessage"]
    },
    "TypeMessage": {
        "recognition": "DirectHit",
        "action": "InputText",
        "input_text": "{{message}}",
        "next": ["SendMessage"]
    },
    "SendMessage": {
        "recognition": "TemplateMatch",
        "template": "chat/btn_send.png",
        "action": "Click",
        "next": ["WaitReply", "ChatComplete"]
    },
    "WaitReply": {
        "recognition": "TemplateMatch",
        "template": "chat/new_reply_indicator.png",
        "timeout": 30000,
        "next": ["ChatComplete"]
    },
    "ChatComplete": {
        "recognition": "DirectHit",
        "action": "DoNothing",
        "next": []
    }
}
