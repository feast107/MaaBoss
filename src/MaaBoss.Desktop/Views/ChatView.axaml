<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MaaBoss.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MaaBoss.Desktop.Views.ChatView"
             x:DataType="vm:ChatViewModel">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,300">
    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="消息沟通" FontSize="24" FontWeight="Bold"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox ItemsSource="{Binding FilterTypes}" SelectedItem="{Binding SelectedFilter}" Width="120"/>
        <Button Content="刷新" Command="{Binding LoadMessagesCommand}" IsEnabled="{Binding !IsBusy}"/>
        <Button Content="全部已读" Command="{Binding MarkAllReadCommand}" IsEnabled="{Binding !IsBusy}"/>
      </StackPanel>
    </StackPanel>

    <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12" Margin="0,4">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding ContactName}" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CandidateInfo}" FontSize="12" Opacity="0.6"/>
                    <Border Background="Red" CornerRadius="10" Width="18" Height="18" IsVisible="{Binding UnreadCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                      <TextBlock Text="{Binding UnreadCount}" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Preview}" FontSize="13" Opacity="0.8" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding Time}" FontSize="11" Opacity="0.5"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12">
      <StackPanel Spacing="8">
        <TextBlock Text="快捷回复" FontSize="16" FontWeight="SemiBold"/>
        <TextBlock Text="{Binding SelectedMessage.ContactName, StringFormat='收件人: {0}'}" FontSize="13" Opacity="0.7"/>
        <TextBox Text="{Binding ReplyMessage}" Watermark="输入回复内容..." AcceptsReturn="True" Height="120" TextWrapping="Wrap"/>
        <Button Content="发送" Command="{Binding SendReplyCommand}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsBusy}"/>
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4" Margin="0,8,0,0">
      <TextBlock Text="提示: 点击左侧消息可选择收件人，然后在右侧输入回复内容。" FontSize="11" Opacity="0.5"/>
    </StackPanel>
  </Grid>
</UserControl>
