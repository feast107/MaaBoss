<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MaaBoss.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="MaaBoss.Desktop.Views.DebugView"
             x:DataType="vm:DebugViewModel">

  <DockPanel LastChildFill="True">
    <!-- 顶部标题 -->
    <TextBlock DockPanel.Dock="Top"
               Text="调试与流程"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,8"/>

    <!-- 底部日志（可向上折叠） -->
    <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
      <ToggleButton Grid.Row="0"
                    Content="▲ 运行日志"
                    IsChecked="{Binding IsLogExpanded}"
                    HorizontalAlignment="Stretch"
                    Padding="8,6"
                    FontSize="12"/>
      <Border Grid.Row="1"
              Background="{DynamicResource SystemChromeLowColor}"
              CornerRadius="8"
              Padding="8"
              IsVisible="{Binding IsLogExpanded}">
        <Grid RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0" MaxHeight="220">
            <TextBlock Text="{Binding LogText}"
                       FontFamily="Consolas, monospace"
                       FontSize="11"
                       TextWrapping="Wrap"/>
          </ScrollViewer>
          <Button Grid.Row="1"
                  Content="清空日志"
                  Command="{Binding ClearLogCommand}"
                  HorizontalAlignment="Right"
                  Padding="10,2"
                  FontSize="12"
                  Margin="0,4,0,0"/>
        </Grid>
      </Border>
    </Grid>

    <!-- 中间主内容 -->
    <ScrollViewer>
      <StackPanel Spacing="12">
        <!-- 截图区域 -->
        <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="屏幕截图" FontSize="16" FontWeight="SemiBold"/>
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    Height="480"
                    HorizontalAlignment="Stretch">
              <Panel>
                <TextBlock Text="暂无截图，点击下方按钮截取"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           IsVisible="{Binding Screenshot, Converter={x:Static ObjectConverters.IsNull}}"/>
                <Image x:Name="ScreenshotImage"
                       Source="{Binding Screenshot}"
                       Stretch="Uniform"
                       IsVisible="{Binding Screenshot, Converter={x:Static ObjectConverters.IsNotNull}}"
                       PointerMoved="ScreenshotImage_OnPointerMoved"
                       PointerExited="ScreenshotImage_OnPointerExited"
                       PointerPressed="ScreenshotImage_OnPointerPressed"
                       PointerWheelChanged="ScreenshotImage_OnPointerWheelChanged"/>
              </Panel>
            </Border>
            <TextBlock Text="{Binding CursorPosText}"
                       FontSize="12"
                       Opacity="0.7"
                       FontFamily="Consolas, monospace"/>
            <TextBlock Text="{Binding DiagnosticText}"
                       FontSize="11"
                       Opacity="0.6"
                       FontFamily="Consolas, monospace"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="截图"
                      Command="{Binding TakeScreenshotCommand}"
                      Padding="12,4"/>
              <Button Content="{Binding LiveButtonText}"
                      Command="{Binding ToggleLiveCaptureCommand}"
                      Padding="12,4"
                      FontSize="12"/>
              <Button Content="OCR 识别"
                      Command="{Binding OcrScreenshotCommand}"
                      Padding="12,4"
                      FontSize="12"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- 预设流程按钮（直接方法调用） -->
        <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="预设流程（方法调用）" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="点击按钮直接调用后台 C# 方法执行完整流程，支持条件判断"
                       FontSize="11" Opacity="0.5"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="消息按钮点击与裁剪"
                      Command="{Binding RunMessageButtonFlowCommand}"
                      Padding="16,8"
                      FontSize="13"
                      Background="{DynamicResource SystemAccentColor}"
                      Foreground="White"
                      CornerRadius="6"
                      Margin="0,0,8,8"/>
            </WrapPanel>
          </StackPanel>
        </Border>

        <!-- 执行状态 -->
        <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12"
                IsVisible="{Binding IsFlowRunning}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="正在执行流程..."
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Content="停止"
                    Command="{Binding StopFlowCommand}"
                    Padding="14,4"
                    FontSize="12"/>
          </StackPanel>
        </Border>

        <!-- Pipeline 执行 -->
        <Border Background="{DynamicResource SystemChromeLowColor}" CornerRadius="8" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="Pipeline 执行" FontSize="14" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBox Text="{Binding PipelineName}"
                       Watermark="Pipeline 名称"
                       Width="200"
                       FontSize="12"/>
              <Button Content="执行" Command="{Binding RunPipelineCommand}" Padding="12,4" FontSize="12"/>
              <Button Content="重载资源" Command="{Binding ReloadResourcesCommand}" Padding="12,4" FontSize="12"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
